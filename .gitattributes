# Default behavior: normalize line endings on commit, OS-native on checkout.
* text=auto eol=lf

# Force CRLF for Windows-only artifacts that need it
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.sln       text eol=crlf

# Force LF for shell scripts
*.sh        text eol=lf

# Source files — text, diffable
*.cs              text diff=csharp
*.csproj          text
*.sln             text
*.props           text
*.targets         text
*.json            text
*.md              text
*.yml             text
*.yaml            text
*.xml             text
*.config          text

# Unity asset / scene files — TEXT (Visible Meta Files + Force Text serialization assumed).
# If the project ever switches to binary serialization these MUST be moved to LFS.
*.unity           text merge=unityyamlmerge eol=lf
*.prefab          text merge=unityyamlmerge eol=lf
*.asset           text merge=unityyamlmerge eol=lf
*.meta            text merge=unityyamlmerge eol=lf
*.mat             text merge=unityyamlmerge eol=lf
*.anim            text merge=unityyamlmerge eol=lf
*.controller      text merge=unityyamlmerge eol=lf
*.physicMaterial  text merge=unityyamlmerge eol=lf
*.physicsMaterial text merge=unityyamlmerge eol=lf
*.physicMaterial2D text merge=unityyamlmerge eol=lf
*.guiskin         text merge=unityyamlmerge eol=lf
*.flare           text merge=unityyamlmerge eol=lf
*.lighting        text merge=unityyamlmerge eol=lf
*.terrainlayer    text merge=unityyamlmerge eol=lf
*.spriteatlas     text merge=unityyamlmerge eol=lf
*.preset          text merge=unityyamlmerge eol=lf

# =====================
#  Git LFS — binary art assets and audio
# =====================
*.fbx       filter=lfs diff=lfs merge=lfs -text
*.obj       filter=lfs diff=lfs merge=lfs -text
*.dae       filter=lfs diff=lfs merge=lfs -text
*.3ds       filter=lfs diff=lfs merge=lfs -text
