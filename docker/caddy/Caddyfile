# Idle MMORPG — Caddy reverse proxy
# Caddy obtains and renews Let's Encrypt certs automatically.
# Replace api.example.com with your real DNS name.

api.example.com {
    encode gzip zstd

    @health path /health/*
    handle @health {
        reverse_proxy api:5000
    }

    handle /hubs/* {
        reverse_proxy api:5000 {
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
            transport http {
                versions 1.1 2
                read_timeout 300s
                write_timeout 300s
            }
        }
    }

    handle {
        reverse_proxy api:5000
    }

    log {
        output stdout
        format json
    }
}

grafana.example.com {
    encode gzip zstd
    reverse_proxy grafana:3000
}
