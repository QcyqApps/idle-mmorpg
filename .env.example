# Copy to .env on the VPS and fill in real values. .env is gitignored.

# Image tag deployed by docker-compose.yml
API_TAG=latest

# Postgres
POSTGRES_PASSWORD=__change_me__

# Redis (no password yet — Redis is on private docker network)

# JWT signing key (HS256). Generate with: openssl rand -base64 64
JWT_SIGNING_KEY=__change_me__

# Google Sign-In Android OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID_ANDROID=__change_me__.apps.googleusercontent.com

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=__change_me__
